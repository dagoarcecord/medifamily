# ============================================================
# MEDIFAMILY - Archivo de ejemplo de variables de entorno
# Copiar a ".env" y ajustar valores reales antes de usar.
# ============================================================

# Entorno: development | testing | production
FLASK_ENV=development
FLASK_APP=app.py

# Clave secreta para sesiones y tokens CSRF
# IMPORTANTE: Cambiar en producción por un valor seguro y aleatorio
SECRET_KEY=cambia-este-valor-por-un-string-muy-largo-y-aleatorio-2026

# Base de datos
# Para desarrollo (SQLite):
DATABASE_URL=sqlite:///database.db
# Para producción (PostgreSQL en Render/Railway):
# DATABASE_URL=postgresql://usuario:password@host:5432/medifamily

# Usuario administrador inicial (creado si no existe)
ADMIN_CORREO=admin@medifamily.local
ADMIN_PASSWORD=Admin123!

# Puerto del servidor
PORT=5000
HOST=0.0.0.0

# Configuración de correo (para futuras notificaciones por email)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@medifamily.app

# Configuración de respaldos automáticos
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
